rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Allow read access to anyone (public images for catalog)
      allow read: if true;
      
      // Allow write access only to authenticated administrators
      allow write: if request.auth != null && (
        request.auth.token.email == 'estebanruiz.12vrgassergio@gmail.com' ||
        request.auth.token.email == 'admin@impulsanet.com' ||
        firestore.exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }
  }
}
